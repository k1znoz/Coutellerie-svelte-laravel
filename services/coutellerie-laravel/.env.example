APP_NAME="${{shared.APP_NAME}}"
APP_ENV=production
APP_KEY="${{shared.APP_KEY}}"
APP_DEBUG=false
APP_URL="${{shared.APP_URL}}"

# Frontend URL pour CORS
FRONTEND_URL="${{shared.FRONTEND_URL}}"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

# Configuration Railpack pour PHP
RAILPACK_PHP_EXTENSIONS=gd,imagick

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Configuration MySQL Railway
DB_CONNECTION=mysql
DB_HOST="${{MYSQLHOST}}"
DB_PORT="${{MYSQLPORT}}"
DB_DATABASE="${{MYSQLDATABASE}}"
DB_USERNAME="${{MYSQLUSER}}"
DB_PASSWORD="${{MYSQLPASSWORD}}"

# Variables MySQL Railway (pour référence)
MYSQL_DATABASE="${{MYSQL_DATABASE}}"
MYSQL_PUBLIC_URL="${{MYSQL_PUBLIC_URL}}"
MYSQL_ROOT_PASSWORD="${{MYSQL_ROOT_PASSWORD}}"
MYSQL_URL="${{MYSQL_URL}}"
MYSQLDATABASE="${{MYSQL_DATABASE}}"
MYSQLHOST="${{RAILWAY_PRIVATE_DOMAIN}}"
MYSQLPASSWORD="${{MYSQL_ROOT_PASSWORD}}"
MYSQLPORT="3306"
MYSQLUSER="root"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Configuration mail minimale (log uniquement)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@coutellerie.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
